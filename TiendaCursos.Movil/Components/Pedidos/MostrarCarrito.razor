@page "/Pedidos/MostrarCarrito"
@inject IRepositorio repositorio
@inject NavigationManager navigationManager
@inject SweetAlertService sweetAlertService
@attribute [Authorize(Roles = "Administrador, Usuario")]

@if (listaPedidoTemporal is null)
{
    <div class="spinner" />

}
else
{
    <GenericList MyList="listaPedidoTemporal">
         <Body>
            <div class="card">
                <div class="card-header">
                    <span>
                        Platillos en carrito
                    </span>
                </div>
                <div class="card-body">
                    <EditForm Model="PedidoDTO" OnValidSubmit="ConfirmarPedidoAsync">
                        <DataAnnotationsValidator />
                        <button class="btn btn-primary mb-3" type="submit">Confirmar Pedido</button>
                    </EditForm>
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Nombre</th>
                                <th>Ingredientes</th>
                                <th>Calorias</th>
                                <th>Precio</th>
                                <th>Cantidad</th>
                                <th>Unidad</th>
                                
                                <th>Imagen</th>
                                <th style="width:180px"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var pedidoTemp in listaPedidoTemporal)
                            {
                              <tr>
                                    <td>
                                        @pedidoTemp.Platillo!.Nombre
                                    </td>
                                    <td>
                                        @pedidoTemp.Platillo!.Ingredientes
                                    </td>
                                    <td>
                                        @pedidoTemp.Platillo!.Calorias

                                    </td>

                                    <td>
                                        @($"{pedidoTemp.Platillo!.Precio:C2}")
                                    </td>
                                    <td>
                                        @pedidoTemp.Platillo!.Cantidad
                                    </td>
                                    <td>
                                        @pedidoTemp.Platillo!.Unidad
                                    </td>
                                    <td>
                                        <img src="@pedidoTemp.Platillo!.Imagen" style="width:100px;" />
                                    </td>
                                    <td>
                                        <button class="btn btn-danger" @onclick=@(() => Borrar(pedidoTemp.Id))>
                                            Borrar
                                        </button>
                                    </td>
                              </tr>  
                                
                            }
                        </tbody>
                    </table>
                </div>
                <div class="card-footer">
                    <span>
                        <strong>Total: @total € </strong>
                    </span>

                </div>
            </div>
         </Body>
    </GenericList>
}

@code {
    public List<PedidoTemporal>? listaPedidoTemporal { get; set; }
    public PedidoDTO PedidoDTO { get; set; } = new();
    private decimal total = 0;

    protected async override Task OnInitializedAsync()
    {
        await CargarAsync();

    }

    private async Task CargarAsync()
    {
        try
        {
            var responseHttp = await repositorio.Get<List<PedidoTemporal>>("api/PedidoTemporal");
            listaPedidoTemporal = responseHttp.Response!;
            total = listaPedidoTemporal.Sum(x => x.Platillo!.Precio);
        }
        catch (Exception ex)
        {
            await sweetAlertService.FireAsync("Error", ex.Message, SweetAlertIcon.Error);

        }
    }
    private async Task Borrar(int id)
    {
       var resultado = await sweetAlertService.FireAsync(new SweetAlertOptions
            {
                Title = "Pregunta",
                Text = "¿Quieres eliminar el registro?",
                Icon = SweetAlertIcon.Question,
                ShowCancelButton = true
            });
        var confirm = string.IsNullOrEmpty(resultado.Value);
    
        if (confirm)
            return;

        var responsehttp = await repositorio.Delete($"api/PedidoTemporal/{id}");
        if (responsehttp.Error)
        {
            if (responsehttp.HttpResponseMessage.StatusCode == System.Net.HttpStatusCode.NotFound)
            {
                navigationManager.NavigateTo("/");
                return;
            }
            var mensajeError = await responsehttp.GetErrorMessageAsync();
            await sweetAlertService.FireAsync("Error", mensajeError, SweetAlertIcon.Error);
            return;

        }

        await CargarAsync();
        var toast = sweetAlertService.Mixin(new SweetAlertOptions
            {
                Toast = true,
                Position = SweetAlertPosition.TopStart,
                ShowConfirmButton = false,
                Timer = 5000
            });
        await toast.FireAsync(icon: SweetAlertIcon.Success, message: "Platillo eliminado.");
    }

    private async void ConfirmarPedidoAsync()
    {
       var resultado = await sweetAlertService.FireAsync(new SweetAlertOptions
       {
           Title = "Pregunta",
           Text = "¿Esta seguro que quieres hacer el pedido?",
           Icon = SweetAlertIcon.Question,
           ShowCancelButton = true
       });
       
       var confirm = string.IsNullOrEmpty(resultado.Value);
       if (confirm)
           return;
    
       var httpResponse = await repositorio.Post("/api/pedidos", PedidoDTO);
       if (httpResponse.Error)
       {
           var message = await httpResponse.GetErrorMessageAsync();
           await sweetAlertService.FireAsync("Error", message, SweetAlertIcon.Error);
           return;
       }
       
        navigationManager.NavigateTo("/Pedidos/PedidoRealizado");
    }
}

